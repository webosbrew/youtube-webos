{
  "name": "youtube-webos",
  "version": "0.5.0",
  "description": "Ad-free YouTube app for webOS",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "package": "ares-package -n dist",
    "deploy": "node tools/deploy.js",
    "inspect": "ares-inspect youtube.leanback.v4",
    "launch": "ares-launch youtube.leanback.v4",
    "manifest": "node tools/gen-manifest.cjs youtube.leanback.v4.manifest.json",
    "prepare": "husky",
    "lint:eslint": "eslint --concurrency auto",
    "lint:tsc": "tsc -b",
    "lint:prettier": "prettier --check .",
    "lint:all": "pnpm run \"/^lint:(?!all)/\""
  },
  "repository": "github:webosbrew/youtube-webos",
  "license": "GPL-3.0-only",
  "bugs": "https://github.com/webosbrew/youtube-webos/issues",
  "homepage": "https://github.com/webosbrew/youtube-webos#readme",
  "dependencies": {
    "@babel/runtime-corejs3": "^7.29.2",
    "core-js-pure": "^3.49.0",
    "regenerator-runtime": "^0.14.1",
    "tiny-sha256": "^1.0.2",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__plugin-transform-runtime": "^7.9.5",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^25.6.0",
    "@webos-tools/cli": "github:fire332/webos-cli#6cfbcf231a0fa1e50519d370ee6e5edc71c4998a",
    "babel-loader": "^10.1.1",
    "babel-plugin-polyfill-corejs3": "^0.14.2",
    "babel-plugin-polyfill-regenerator": "^0.6.8",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-regexp": "^3.1.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.9",
    "postcss-load-config": "^6.0.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.2.1",
    "prettier": "^3.8.2",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "transform-async-modules-webpack-plugin": "^1.1.1",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2",
    "which-builtin-type": "^1.2.1"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "download"
    },
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
